# ====== 源库（主业务库）配置 ======
SOURCE_DB_HOST=your-source-db-host
SOURCE_DB_PORT=3306
SOURCE_DB_USER=your-source-user
SOURCE_DB_PASSWORD=your-source-password
SOURCE_DB_NAME=unicorn_pro
SOURCE_DB_POOL_SIZE=10

# ====== 目标库（历史库）配置 ======
TARGET_DB_HOST=your-target-db-host
TARGET_DB_PORT=3306
TARGET_DB_USER=your-target-user
TARGET_DB_PASSWORD=your-target-password
TARGET_DB_NAME=unicorn_pro_history
TARGET_DB_POOL_SIZE=10

# ====== 数据迁移配置 ======
# 归档截止时间（迁移该时间点及之前的数据）
ARCHIVE_CUTOFF_DATE=2025-12-31
# 每次迁移的时间窗口大小（单位：天）
BATCH_WINDOW_DAYS=7
# 批量插入每批的行数
BATCH_INSERT_SIZE=1000
# 流式查询的并发数
STREAM_CONCURRENCY=4
# 分页拉取每页行数（避免全量加载千万行到内存）
FETCH_PAGE_SIZE=5000

# ====== 数据库超时配置（防死锁关键参数）======
# 获取连接池连接的超时时间（毫秒）
ACQUIRE_TIMEOUT_MS=30000
# 单条SQL语句执行超时（毫秒），对应 MySQL max_execution_time
STATEMENT_TIMEOUT_MS=60000
# 行锁等待超时（秒），对应 MySQL innodb_lock_wait_timeout
LOCK_WAIT_TIMEOUT_SECS=10
# DDL操作（如 DROP PARTITION）超时（毫秒）
DDL_TIMEOUT_MS=120000

# ====== 补偿机制配置 ======
# 是否启用补偿日志（清理失败时记录，后续异步重试）
COMPENSATION_ENABLED=true
# 最大重试次数
COMPENSATION_MAX_RETRIES=5
# 首次重试延迟（毫秒）
COMPENSATION_RETRY_DELAY_MS=60000
# 重试退避倍数（指数退避）
COMPENSATION_RETRY_BACKOFF_MULTIPLIER=2
# 补偿日志存放目录
COMPENSATION_LOG_DIR=./logs/compensation

# ====== 阿里云 OSS 配置（极寒归档上传目标）======
OSS_ENABLED=false
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_PREFIX=glacier-archive
OSS_SHARD_SIZE_MB=100
OSS_CONCURRENCY=5
OSS_MAX_RETRIES=3
OSS_SECURE=true

# ====== Parquet 导出配置 ======
PARQUET_ENABLED=true
PARQUET_OUTPUT_DIR=./data/parquet
PARQUET_ROW_GROUP_SIZE=125000
# 压缩算法：UNCOMPRESSED | SNAPPY | GZIP | BROTLI | LZ4 | ZSTD
PARQUET_COMPRESSION=ZSTD
PARQUET_COMPRESSION_LEVEL=3
PARQUET_PAGE_SIZE=1048576

# ====== 极寒归档配置 ======
GLACIER_ENABLED=false
# 数据在历史库中保留 N 年后自动降级到 OSS + Parquet
GLACIER_RETENTION_YEARS=5
# 极寒归档调度 Cron（默认每周日凌晨 3 点执行）
GLACIER_SCHEDULE_CRON=0 0 3 * * 0
GLACIER_SCAN_BATCH_SIZE=100
GLACIER_TEMP_DIR=./data/temp
# true=上传后保留本地 Parquet 文件，false=上传成功即删除
GLACIER_KEEP_LOCAL_PARQUET=false
# 虚拟路由存根表名（存放在历史库中）
GLACIER_STUBS_TABLE=glacier_virtual_stubs
# 存根创建成功后是否从历史库物理删除源数据
GLACIER_REMOVE_SOURCE=false

# ====== 定时调度配置 ======
# Cron 表达式（默认每天凌晨 2 点执行）
CRON_SCHEDULE=0 0 2 * * *
# 时区
CRON_TIMEZONE=Asia/Shanghai

# ====== 日志配置 ======
LOG_LEVEL=info
LOG_DIR=./logs

# ====== 运行模式 ======
# true=仅模拟运行不实际删除源库数据，false=实际执行清理
DRY_RUN=true
