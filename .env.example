# ====== 源库（主业务库）配置 ======
SOURCE_DB_HOST=your-source-db-host
SOURCE_DB_PORT=3306
SOURCE_DB_USER=your-source-user
SOURCE_DB_PASSWORD=your-source-password
SOURCE_DB_NAME=unicorn_pro

# ====== 目标库（历史库）配置 ======
TARGET_DB_HOST=your-target-db-host
TARGET_DB_PORT=3306
TARGET_DB_USER=your-target-user
TARGET_DB_PASSWORD=your-target-password
TARGET_DB_NAME=unicorn_pro_history

# ====== 数据迁移配置 ======
# 归档截止时间（迁移该时间点及之前的数据）
ARCHIVE_CUTOFF_DATE=2025-12-31
# 每次迁移的时间窗口大小（单位：天）
BATCH_WINDOW_DAYS=7
# 批量插入每批的行数
BATCH_INSERT_SIZE=1000
# 流式查询的并发数
STREAM_CONCURRENCY=4

# ====== 定时调度配置 ======
# Cron 表达式（默认每天凌晨 2 点执行）
CRON_SCHEDULE=0 0 2 * * *
# 时区
CRON_TIMEZONE=Asia/Shanghai

# ====== 日志配置 ======
LOG_LEVEL=info
LOG_DIR=./logs

# ====== 运行模式 ======
# true=仅模拟运行不实际删除源库数据，false=实际执行清理
DRY_RUN=true
